# Google Apps Script - RSVP (somente no servidor)
# Configure estas variáveis no painel da Vercel para produção
# Copie para .env.local para desenvolvimento local

# RSVP: script que insere confirmações em uma planilha
GOOGLE_APPS_SCRIPT_RSVP_URL=

# ---------------------------------------------------------------------------
# Upload de mídias → Google Drive (recomendado: OAuth da conta dona da pasta)
# Service Account NÃO funciona em Drive pessoal (sem cota de armazenamento).
# ---------------------------------------------------------------------------

# 1. Cloud Console → ative Google Drive API
# 2. Credentials → OAuth client ID → tipo "Desktop app"
# 3. Preencha CLIENT_ID e CLIENT_SECRET abaixo
# 4. Rode: npm run drive:oauth  → cole o REFRESH_TOKEN gerado
# 5. GOOGLE_DRIVE_FOLDER_ID = ID da pasta (URL do Drive)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
GOOGLE_DRIVE_FOLDER_ID=

# Alternativa (somente Shared Drive / Google Workspace):
# GOOGLE_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
# GOOGLE_DRIVE_FOLDER_ID=

# Opcional: origin público do site (ajuda CORS do upload resumível)
# NEXT_PUBLIC_SITE_URL=https://seu-dominio.vercel.app

# Data e horário do casamento (público, exibido no frontend)
NEXT_PUBLIC_WEDDING_DATE=2026-11-28T16:30:00
